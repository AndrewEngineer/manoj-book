<script>
function showView(id) {
  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  window.scrollTo(0, 0);
}

// "Read Online" buttons → show chapters view
document.querySelectorAll('.btn-login, .btn-primary').forEach(btn => {
  btn.addEventListener('click', e => { e.preventDefault(); showView('view-chapters'); });
});

// Chapter list items → show reading view
document.querySelectorAll('.chapter-list-item').forEach(item => {
  item.addEventListener('click', e => { e.preventDefault(); showView('view-reading'); });
});

// Home icon in chapter nav → back to chapters
document.querySelector('.chapter-nav')?.addEventListener('click', e => {
  if (e.target.textContent.trim() === 'Top') return; // let Top scroll
});

// Logo → back to landing
document.querySelector('.logo').addEventListener('click', e => {
  e.preventDefault(); showView('view-landing');
});
document.querySelector('.logo').style.cursor = 'pointer';

// Nav links
document.querySelectorAll('.nav-links a:not(.btn-login)').forEach(link => {
  link.addEventListener('click', e => {
    const current = document.querySelector('.view.active');
    if (current.id !== 'view-landing') {
      e.preventDefault();
      showView('view-landing');
      setTimeout(() => {
        const target = document.querySelector(link.getAttribute('href'));
        if (target) target.scrollIntoView({ behavior: 'smooth' });
      }, 100);
    }
  });
});

// Members nav "All Chapters" → back to chapters list
document.querySelectorAll('.members-nav a').forEach(link => {
  link.addEventListener('click', e => e.preventDefault());
});

// Carousel logic
document.querySelectorAll('[data-carousel]').forEach(carousel => {
  const slides = carousel.querySelector('.carousel-slides');
  const slideEls = carousel.querySelectorAll('.carousel-slide');
  const dots = carousel.querySelectorAll('.carousel-dot');
  const prevBtn = carousel.querySelector('[data-prev]');
  const nextBtn = carousel.querySelector('[data-next]');
  let current = 0;
  const total = slideEls.length;

  function goTo(index) {
    current = (index + total) % total;
    slides.style.transform = `translateX(-${current * 100}%)`;
    dots.forEach((d, i) => d.classList.toggle('active', i === current));
  }

  prevBtn.addEventListener('click', () => goTo(current - 1));
  nextBtn.addEventListener('click', () => goTo(current + 1));
  dots.forEach(dot => {
    dot.addEventListener('click', () => goTo(parseInt(dot.dataset.dot)));
  });
});
</script>

